{
  "version": "1.0.0",
  "theme_name": "RPP",
  "repo_url": "https://github.com/ahmedzaidd1-cmyk/RPP",
  "support_url": "https://github.com/ahmedzaidd1-cmyk/RPP",
  "author_email": "ahmedzaidd1@gmail.com",
  "description": {
    "ar": "ثيم RPP الاحترافي",
    "en": "RPP Professional Theme"
  },
  "features": [
    "mega-menu",
    "fonts",
    "color",
    "breadcrumb",
    "unite-cards-height",
    "component-featured-products",
    "component-fixed-banner",
    "component-fixed-products",
    "component-products-slider",
    "component-photos-slider",
    "component-parallax-background",
    "component-testimonials",
    "component-square-photos",
    "component-store-features",
    "component-youtube",
    "menu-images",
    "filters"
  ],
  "settings": [
    {
      "id": "header_is_sticky",
      "type": "boolean",
      "format": "switch",
      "label": "تثبيت القائمة",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "important_links",
      "type": "boolean",
      "format": "switch",
      "label": "روابط الصفحات الهامة",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "footer_is_dark",
      "type": "boolean",
      "format": "switch",
      "label": "فوتر داكن",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "show_payments",
      "type": "boolean",
      "format": "switch",
      "label": "عرض وسائل الدفع",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "show_search",
      "type": "boolean",
      "format": "switch",
      "label": "عرض البحث",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "enable_add_product_toast",
      "type": "boolean",
      "format": "switch",
      "label": "إشعار الإضافة للسلة",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "sticky_add_to_cart",
      "type": "boolean",
      "format": "switch",
      "label": "تثبيت زر الإضافة في الجوال",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "imageZoom",
      "type": "boolean",
      "format": "switch",
      "label": "تكبير صور المنتج",
      "icon": "sicon-toggle-off",
      "value": false
    },
    {
      "id": "enable_more_menu",
      "type": "boolean",
      "format": "switch",
      "label": "قائمة المزيد",
      "icon": "sicon-toggle-off",
      "value": true
    },
    {
      "id": "vertical_fixed_products",
      "type": "boolean",
      "format": "switch",
      "label": "منتجات عمودية",
      "icon": "sicon-toggle-off",
      "value": true
    }
  ],
  "components": [
    {
      "name": "enhanced-slider",
      "title": "السلايدر الرئيسي",
      "icon": "sicon-image-carousel",
      "path": "home.enhanced-slider",
      "fields": [
        {
          "id": "slides",
          "type": "collection",
          "label": "الشرائح",
          "fields": [
            {
              "id": "image",
              "type": "image",
              "label": "الصورة",
              "required": true
            },
            {
              "id": "title",
              "type": "text",
              "label": "العنوان",
              "multilanguage": true
            },
            {
              "id": "description",
              "type": "textarea",
              "label": "الوصف",
              "multilanguage": true
            },
            {
              "id": "without_overlay",
              "type": "boolean",
              "format": "switch",
              "label": "إزالة التعتيم",
              "value": false
            }
          ]
        }
      ]
    },
    {
      "name": "enhanced-square-banners",
      "title": "البانرات الترويجية",
      "icon": "sicon-image",
      "path": "home.enhanced-square-banners",
      "fields": [
        {
          "id": "banners",
          "type": "collection",
          "label": "البانرات",
          "fields": [
            {
              "id": "image",
              "type": "image",
              "label": "الصورة",
              "required": true
            },
            {
              "id": "title",
              "type": "text",
              "label": "العنوان",
              "multilanguage": true
            },
            {
              "id": "url",
              "type": "url",
              "label": "الرابط"
            }
          ]
        }
      ]
    },
    {
      "name": "custom-testimonials",
      "title": "آراء العملاء",
      "icon": "sicon-chat-bubbles",
      "path": "home.custom-testimonials",
      "fields": [
        {
          "id": "items",
          "type": "collection",
          "label": "التقييمات",
          "fields": [
            {
              "id": "name",
              "type": "text",
              "label": "اسم العميل"
            },
            {
              "id": "avatar",
              "type": "image",
              "label": "صورة العميل"
            },
            {
              "id": "stars",
              "type": "number",
              "label": "النجوم (1-5)",
              "value": 5
            },
            {
              "id": "text",
              "type": "textarea",
              "label": "التقييم",
              "multilanguage": true
            }
          ]
        }
      ]
    },
    {
      "name": "brands",
      "title": "الماركات",
      "icon": "sicon-award-ribbon",
      "path": "home.brands",
      "fields": [
        {
          "id": "brands",
          "type": "brands",
          "label": "الماركات"
        }
      ]
    },
    {
      "name": "featured-products-style1",
      "title": "منتجات مميزة",
      "icon": "sicon-shopping-bag",
      "path": "home.featured-products-style1",
      "fields": [
        {
          "id": "title",
          "type": "text",
          "label": "العنوان",
          "multilanguage": true
        },
        {
          "id": "products",
          "type": "categories",
          "label": "التصنيف"
        },
        {
          "id": "limit",
          "type": "number",
          "label": "عدد المنتجات",
          "value": 8
        }
      ]
    },
    {
      "name": "featured-products-style2",
      "title": "منتجات مميزة (نمط 2)",
      "icon": "sicon-shopping-bag",
      "path": "home.featured-products-style2",
      "fields": [
        {
          "id": "title",
          "type": "text",
          "label": "العنوان",
          "multilanguage": true
        },
        {
          "id": "products",
          "type": "categories",
          "label": "التصنيف"
        },
        {
          "id": "limit",
          "type": "number",
          "label": "عدد المنتجات",
          "value": 8
        },
        {
          "id": "is_slider",
          "type": "boolean",
          "label": "عرض كسلايدر",
          "value": false
        }
      ]
    },
    {
      "name": "featured-products-style3",
      "title": "منتجات مميزة (نمط 3)",
      "icon": "sicon-shopping-bag",
      "path": "home.featured-products-style3",
      "fields": [
        {
          "id": "title",
          "type": "text",
          "label": "العنوان",
          "multilanguage": true
        },
        {
          "id": "products",
          "type": "categories",
          "label": "التصنيف"
        },
        {
          "id": "limit",
          "type": "number",
          "label": "عدد المنتجات",
          "value": 4
        }
      ]
    },
    {
      "name": "products-slider",
      "title": "سلايدر المنتجات",
      "icon": "sicon-image-carousel",
      "path": "home.products-slider",
      "fields": [
        {
          "id": "title",
          "type": "text",
          "label": "العنوان",
          "multilanguage": true
        },
        {
          "id": "products",
          "type": "categories",
          "label": "التصنيف"
        },
        {
          "id": "limit",
          "type": "number",
          "label": "عدد المنتجات",
          "value": 8
        }
      ]
    },
    {
      "name": "latest-products",
      "title": "أحدث المنتجات",
      "icon": "sicon-shopping-bag",
      "path": "home.latest-products",
      "fields": []
    },
    {
      "name": "fixed-products",
      "title": "منتجات ثابتة",
      "icon": "sicon-shopping-bag",
      "path": "home.fixed-products",
      "fields": [
        {
          "id": "title",
          "type": "text",
          "label": "العنوان",
          "multilanguage": true
        },
        {
          "id": "products",
          "type": "products",
          "label": "المنتجات"
        },
        {
          "id": "limit",
          "type": "number",
          "label": "عدد المنتجات",
          "value": 8
        }
      ]
    },
    {
      "name": "fixed-banner",
