<section class="rpp-banners">
  <div class="container">
    <div class="banners-grid reveal">
      {% set main = component.banners[0] %}
      {% if main %}
      <div class="banner-card">
        <div class="banner-bg" style="background-image:url('{{ main.image }}')"></div>
        <div class="banner-overlay" style="background:linear-gradient(to left,rgba(26,26,46,.8) 40%,rgba(26,26,46,.3) 100%)"></div>
        <div class="banner-body">
          <div class="banner-label">عرض خاص</div>
          <div class="banner-title">{{ main.title }}</div>
          {% if main.url %}<a href="{{ main.url }}" class="banner-cta">تسوق الآن ←</a>{% endif %}
        </div>
      </div>
      {% endif %}
      <div style="display:flex;flex-direction:column;gap:20px">
        {% for banner in component.banners|slice(1,2) %}
        <div class="banner-card banner-sm">
          <div class="banner-bg" style="background-image:url('{{ banner.image }}')"></div>
          <div class="banner-overlay" style="background:linear-gradient(to top,rgba(26,26,46,.85),transparent 60%)"></div>
          <div class="banner-body">
            <div class="banner-title">{{ banner.title }}</div>
            {% if banner.url %}<a href="{{ banner.url }}" class="banner-cta">تسوق الآن ←</a>{% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
