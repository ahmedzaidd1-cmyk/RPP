{#
| youtube_id | string |
#}
{% if youtube_id %}
<section class="s-block container" style="padding:70px 0">
  <div style="border-radius:14px;overflow:hidden;aspect-ratio:16/9;max-width:900px;margin:0 auto;background:#000">
    <iframe
      src="https://www.youtube.com/embed/{{ youtube_id }}?rel=0"
      title="YouTube video player"
      style="width:100%;height:100%;border:0;display:block"
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
</section>
{% endif %}
