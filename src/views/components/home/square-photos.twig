{#
| items[].url       | string |
| items[].image.url | string |
| items[].text      | string |
#}
{% if items|length %}
<section class="s-block container" style="padding:60px 0">
  {% if title %}
  <div class="sec-header reveal">
    <div><div class="rpp-badge">أقسام</div><h2 class="rpp-title">{{ title }}</h2></div>
  </div>
  {% endif %}
  <div class="reveal" style="transition-delay:.1s;display:grid;grid-template-columns:repeat({{ [items|length,6]|min }},1fr);gap:16px">
    {% for item in items %}
    <a href="{{ item.url }}" style="display:block;border-radius:12px;overflow:hidden;position:relative;aspect-ratio:1;background:#EEF0F5;cursor:pointer;transition:transform .3s"
       onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
      {% if item.image.url %}
      <img src="{{ item.image.url }}" alt="{{ item.text }}" style="width:100%;height:100%;object-fit:cover;display:block">
      {% endif %}
      {% if item.text %}
      <div style="position:absolute;bottom:0;left:0;right:0;padding:12px;background:linear-gradient(to top,rgba(26,26,46,.85),transparent);color:white;font-weight:700;font-size:0.88rem;text-align:center">
        {{ item.text }}
      </div>
      {% endif %}
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
