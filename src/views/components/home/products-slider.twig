{#
| Variable              | Type    |
|-----------------------|---------|
| products.source       | string  |
| products.source_value | ?int[]  |
| title                 | string  |
| display_all_url       | ?string |
| limit                 | int     |
| position              | int     |
#}
<section class="s-block container" style="padding:70px 0">
  <div class="sec-header reveal">
    <div>
      <div class="rpp-badge">أحدث المنتجات</div>
      <h2 class="rpp-title">{{ title ?? 'تسوق الآن' }} <span class="hl">🛍️</span></h2>
    </div>
    {% if display_all_url %}
    <a href="{{ display_all_url }}" class="btn btn-outline btn-sm">عرض الكل ←</a>
    {% endif %}
  </div>
  {% if products %}
  <salla-products-slider
    source="{{ products.source }}"
    limit="{{ limit ?? 8 }}"
    autoplay
    source-value="{{ products.source_value|json_encode }}"
    display-all-url="{{ display_all_url }}"
    block-title=""
    slider-id="rpp-ps-{{ position }}"
  ></salla-products-slider>
  {% endif %}
</section>
