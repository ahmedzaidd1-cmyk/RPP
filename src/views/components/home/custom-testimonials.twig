<section class="rpp-testimonials">
  <div class="container">
    <div class="testimonials-inner">
      <div class="testimonials-header reveal">
        <div class="badge" style="justify-content:center;color:rgba(230,57,70,.9)">آراء العملاء</div>
        <h2 class="section-heading" style="color:white;text-align:center">ماذا يقولون <span class="highlight">عنا؟</span></h2>
      </div>
      <div class="testi-grid">
        {% for review in component.items %}
        <div class="testi-card reveal" style="transition-delay:{{ loop.index0 * 0.1 }}s">
          <div class="testi-stars">{% for i in 1..review.stars %}★{% endfor %}</div>
          <p class="testi-text">{{ review.text }}</p>
          <div class="testi-author">
            {% if review.avatar %}
              <img src="{{ review.avatar }}" alt="{{ review.name }}" class="testi-avatar" style="object-fit:cover;">
            {% else %}
              <div class="testi-avatar">{{ review.name|slice(0,1) }}</div>
            {% endif %}
            <div>
              <span class="testi-name">{{ review.name }}</span>
              <span class="testi-meta">✓ مشتري موثق</span>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
