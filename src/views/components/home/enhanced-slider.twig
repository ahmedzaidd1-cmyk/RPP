<section class="rpp-hero">
  <div class="hero-slides" id="heroSlides">
    <div class="hero-progress"><div class="hero-progress-bar" id="heroProgress"></div></div>

    {% for slide in component.slides %}
    <div class="hero-slide {% if loop.first %}active{% endif %}">
      <div class="hero-slide-bg" style="background-image:url('{{ slide.image }}')"></div>
      <div class="hero-slide-content">
        <div class="container" style="width:100%">
          <div class="hero-content-inner">
            <div class="slide-label"><span class="slide-pulse"></span><span>{{ app.locale == 'ar' ? store.name : store.name }}</span></div>
            {% if slide.title %}
            <h1 class="hero-title">{{ slide.title }}</h1>
            {% endif %}
            {% if slide.description %}
            <p class="hero-sub">{{ slide.description }}</p>
            {% endif %}
            <div class="hero-btns">
              <a href="{{ store.urls.products }}" class="btn btn-primary">تسوق الآن ←</a>
              <a href="{{ store.urls.offers }}" class="btn btn-white-outline">العروض</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}

    <button class="hero-arrow hero-prev" id="heroPrev">&#8594;</button>
    <button class="hero-arrow hero-next" id="heroNext">&#8592;</button>

    <div class="hero-dots" id="heroDots">
      {% for slide in component.slides %}
      <button class="hero-dot {% if loop.first %}active{% endif %}"></button>
      {% endfor %}
    </div>

    <div class="slide-counter">
      <span class="slide-current" id="slideCurrentNum">01</span>
      <span>/</span>
      <span>{{ component.slides|length|number_format(2, '0') }}</span>
    </div>
  </div>
</section>

<!-- Features Bar -->
<div class="rpp-features-bar">
  <div class="container">
    <div class="features-grid">
      <div class="feat-item">
        <div class="feat-icon">🚚</div>
        <div class="feat-text"><strong>{{ settings.feat1_title ?? 'شحن مجاني' }}</strong><span>{{ settings.feat1_desc ?? 'على الطلبات فوق 150 ريال' }}</span></div>
      </div>
      <div class="feat-item">
        <div class="feat-icon">🔄</div>
        <div class="feat-text"><strong>{{ settings.feat2_title ?? 'إرجاع مجاني' }}</strong><span>{{ settings.feat2_desc ?? 'خلال 30 يوماً دون شرط' }}</span></div>
      </div>
      <div class="feat-item">
        <div class="feat-icon">🔒</div>
        <div class="feat-text"><strong>{{ settings.feat3_title ?? 'دفع آمن 100%' }}</strong><span>{{ settings.feat3_desc ?? 'تشفير SSL عالي الأمان' }}</span></div>
      </div>
      <div class="feat-item">
        <div class="feat-icon">🎧</div>
        <div class="feat-text"><strong>{{ settings.feat4_title ?? 'دعم 24/7' }}</strong><span>{{ settings.feat4_desc ?? 'فريق خدمة دائم الاستعداد' }}</span></div>
      </div>
    </div>
  </div>
</div>

