{% if component.slides|length %}
<section class="rpp-hero">
  <div class="hero-slides" id="heroSlides-{{ position }}">
    <div class="hero-progress"><div class="hero-bar" id="heroBar-{{ position }}"></div></div>
    {% for slide in component.slides %}
    {% set primary_url = slide.url|default(store.urls.products) %}
    {% set secondary_url = store.urls.products|default(primary_url) %}
    <div class="hero-slide {% if loop.first %}active{% endif %}">
      <div class="hero-bg" style="background-image:url('{{ slide.image }}')"></div>
      <div class="hero-content">
        <div class="container" style="width:100%">
          <div class="hero-inner">
            <div class="hero-tag"><span class="hero-pulse"></span><span>{{ store.name }}</span></div>
            {% if slide.title %}<h1 class="hero-h1">{{ slide.title }}</h1>{% endif %}
            {% if slide.description %}<p class="hero-p">{{ slide.description }}</p>{% endif %}
            <div class="hero-btns">
              <a href="{{ primary_url }}" class="btn btn-primary">تسوق الآن ←</a>
              <a href="{{ secondary_url }}" class="btn btn-white-outline">المنتجات</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
    {% if component.slides|length > 1 %}
    <button class="hero-arr hero-prev" id="heroPrev-{{ position }}" type="button" aria-label="Previous slide">&#8594;</button>
    <button class="hero-arr hero-next" id="heroNext-{{ position }}" type="button" aria-label="Next slide">&#8592;</button>
    <div class="hero-dots" id="heroDots-{{ position }}">
      {% for slide in component.slides %}
      <button class="hero-dot {% if loop.first %}active{% endif %}" type="button" aria-label="Slide {{ loop.index }}"></button>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>

<div class="rpp-feats">
  <div class="container">
    <div class="feats-grid">
      <div class="feat"><div class="feat-ico">🚚</div><div><strong>شحن سريع</strong><span>لجميع المناطق</span></div></div>
      <div class="feat"><div class="feat-ico">✅</div><div><strong>جودة مضمونة</strong><span>منتجات معتمدة</span></div></div>
      <div class="feat"><div class="feat-ico">🔒</div><div><strong>دفع آمن</strong><span>تشفير SSL</span></div></div>
      <div class="feat"><div class="feat-ico">🎧</div><div><strong>دعم 24/7</strong><span>فريق متخصص</span></div></div>
    </div>
  </div>
</div>

<div class="rpp-offerbar">
  <div class="offer-track">
    <div class="offer-item"><span class="offer-dot"></span><span>🔥 عروض حصرية — خصم حتى 30%</span></div>
    <div class="offer-item"><span class="offer-dot"></span><span>🚚 شحن مجاني على الطلبات فوق 200 ريال</span></div>
    <div class="offer-item"><span class="offer-dot"></span><span>✅ منتجات معتمدة وموثوقة</span></div>
    <div class="offer-item"><span class="offer-dot"></span><span>💳 أقساط بدون فوائد مع تمارا وتابي</span></div>
