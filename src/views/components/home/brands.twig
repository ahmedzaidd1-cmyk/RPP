<section class="rpp-brands">
  <div class="container">
    <div style="text-align:center;margin-bottom:8px" class="reveal">
      <div class="badge" style="justify-content:center">شركاؤنا</div>
      <h2 class="section-heading">الماركات التي <span class="highlight">نثق بها</span></h2>
    </div>
  </div>
  <div class="brands-track-wrap">
    <div class="brands-track">
      {% for brand in component.brands %}
        {% if brand.logo %}
          <img src="{{ brand.logo }}" alt="{{ brand.name }}" class="brand-logo" style="width:auto;padding:8px;">
        {% else %}
          <div class="brand-logo">{{ brand.name }}</div>
        {% endif %}
      {% endfor %}
      {% for brand in component.brands %}
        {% if brand.logo %}
          <img src="{{ brand.logo }}" alt="{{ brand.name }}" class="brand-logo" style="width:auto;padding:8px;">
        {% else %}
          <div class="brand-logo">{{ brand.name }}</div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
