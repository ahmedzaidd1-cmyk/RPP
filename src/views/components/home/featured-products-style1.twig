{% set component_id='rpp-fp1-' ~ position %}

<section class="rpp-products s-block s-block-tabs s-block--special-products container" id="{{ component_id }}" style="padding:70px 0">

  <div class="sec-header reveal">
    <div>
      <div class="rpp-badge">منتجاتنا</div>
      <h2 class="rpp-title">
        {{ main_product.title ?? trans('blocks.home.featured_products') }}
        <span class="hl">المميزة</span>
      </h2>
    </div>

    {% if items|length > 1 %}
    <div class="tabs" style="display:flex;gap:4px;background:#EEF0F5;border-radius:8px;padding:4px">
      {% for section in items %}
      <button
        type="button"
        data-target="{{ component_id }}-{{ section.id }}"
        data-component-id="{{ component_id }}"
        class="tab-trigger {{ loop.first ? 'is-active' : '' }}"
        style="padding:7px 18px;border-radius:6px;font-size:0.85rem;font-weight:700;font-family:Tajawal,sans-serif"
      >
        {{ section.title }}
      </button>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <div class="tabs-wrapper reveal" style="transition-delay:.1s">
    {% for section in items %}
    <div
      id="{{ component_id }}-{{ section.id }}"
      class="tabs__item {{ loop.first ? 'is-active' : '' }}"
      style="display:{{ loop.first ? 'grid' : 'none' }};grid-template-columns:repeat(4,1fr);gap:18px"
    >
      {% for product in section.products|slice(0,8) %}
        <salla-product-card product-id="{{ product.id }}"></salla-product-card>
      {% endfor %}
    </div>
    {% endfor %}
  </div>

</section>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const triggers = document.querySelectorAll("#{{ component_id }} .tab-trigger");

  triggers.forEach(btn => {
    btn.addEventListener("click", function(){

      const wrapper = document.querySelector("#{{ component_id }}");
      const target = this.dataset.target;

      // remove active class
      wrapper.querySelectorAll(".tab-trigger").forEach(t => t.classList.remove("is-active"));
      this.classList.add("is-active");

      // hide all tabs
      wrapper.querySelectorAll(".tabs__item").forEach(tab => {
        tab.style.display = "none";
      });

      // show selected
      const activeTab = document.getElementById(target);
      if(activeTab){
        activeTab.style.display = "grid";
      }

    });
  });

});
</script>
