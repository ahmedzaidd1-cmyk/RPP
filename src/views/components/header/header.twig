{% set store = store %}
{% set cart = cart %}

<!-- TOP BAR -->
{% if settings.important_links %}
<div class="top-bar">
  <div class="container">
    <div class="top-bar-inner">
      <div class="top-bar-left">
        {% if store.phone %}
        <div class="top-bar-item">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M22 16.92V19a2 2 0 01-2.18 2A19.8 19.8 0 013 4.18 2 2 0 015 2h2.09a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span>{{ store.phone }}</span>
        </div>
        {% endif %}
        {% if store.email %}
        <div class="top-bar-item">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
          <span>{{ store.email }}</span>
        </div>
        {% endif %}
      </div>
      <div class="top-bar-right">
        <div class="social-bar">
          {% if store.social.twitter %}<a href="{{ store.social.twitter }}" class="soc">𝕏</a>{% endif %}
          {% if store.social.instagram %}<a href="{{ store.social.instagram }}" class="soc">📷</a>{% endif %}
          {% if store.social.snapchat %}<a href="{{ store.social.snapchat }}" class="soc">👻</a>{% endif %}
        </div>
        <div class="lang-pill">
          <button class="lang-btn {% if app.locale == 'ar' %}active{% endif %}" onclick="salla.lang.change('ar')">عربي</button>
          <button class="lang-btn {% if app.locale == 'en' %}active{% endif %}" onclick="salla.lang.change('en')">EN</button>
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}

<!-- MAIN HEADER -->
<header class="rpp-header {% if settings.header_is_sticky %}header_is_sticky{% endif %}">
  <div class="container">
    <div class="nav-inner">
      <a href="{{ store.url }}" class="nav-logo">
        {% if store.logo %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" style="height:42px;width:auto;object-fit:contain;">
        {% else %}
          <div class="logo-mark">{{ store.name|slice(0,1) }}</div>
          <div class="logo-words">
            <span class="logo-name">{{ store.name }}</span>
            <span class="logo-tagline">Powered by Salla</span>
          </div>
        {% endif %}
      </a>

      {% if settings.show_search %}
      <div class="nav-search">
        <salla-search-form></salla-search-form>
      </div>
      {% endif %}

      <div class="nav-actions">
        <a class="nav-action" href="{{ store.urls.customer }}">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>حسابي</span>
        </a>
        <a class="nav-action" href="{{ store.urls.wishlist }}">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          <span>المفضلة</span>
        </a>
        <salla-cart-summary class="nav-action">
          <span class="cart-badge">{{ cart.count }}</span>
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span>السلة</span>
        </salla-cart-summary>
      </div>
    </div>
  </div>

  <div class="nav-main">
    <div class="container">
      <div class="nav-main-inner">
        <a href="{{ store.url }}" class="nav-link">الرئيسية</a>
        {% for item in menus.header %}
          <a href="{{ item.url }}" class="nav-link">{{ item.name }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</header>
