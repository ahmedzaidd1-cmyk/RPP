<footer class="rpp-footer {% if settings.footer_is_dark %}footer-dark{% endif %}">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px">
          {% if store.logo %}
            <img src="{{ store.logo }}" alt="{{ store.name }}" style="height:40px;width:auto;filter:brightness(0) invert(1);">
          {% else %}
            <div class="logo-mark">{{ store.name|slice(0,1) }}</div>
            <div class="logo-words">
              <span class="logo-name" style="color:white">{{ store.name }}</span>
              <span class="logo-tagline" style="color:rgba(255,255,255,.35)">Powered by Salla</span>
            </div>
          {% endif %}
        </div>
        {% if store.description %}
        <p>{{ store.description }}</p>
        {% endif %}
        <div class="footer-social">
          {% if store.social.twitter %}<a href="{{ store.social.twitter }}" class="footer-soc">𝕏</a>{% endif %}
          {% if store.social.instagram %}<a href="{{ store.social.instagram }}" class="footer-soc">📷</a>{% endif %}
          {% if store.social.snapchat %}<a href="{{ store.social.snapchat }}" class="footer-soc">👻</a>{% endif %}
        </div>
        {% if settings.show_payments %}
        <div class="payment-methods">
          <span class="pay-badge">Visa</span>
          <span class="pay-badge">Mada</span>
          <span class="pay-badge">STC Pay</span>
          <span class="pay-badge">Apple Pay</span>
          <span class="pay-badge">Tamara</span>
        </div>
        {% endif %}
      </div>

      <!-- Categories -->
      <div class="footer-col">
        <h4>أقسام المتجر</h4>
        <ul>
          {% for category in categories|slice(0,6) %}
          <li><a href="{{ category.url }}">{{ category.name }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h4>الشركة</h4>
        <ul>
          <li><a href="{{ store.urls.about }}">من نحن</a></li>
          <li><a href="{{ store.urls.privacy }}">سياسة الخصوصية</a></li>
          <li><a href="{{ store.urls.terms }}">الشروط والأحكام</a></li>
          <li><a href="{{ store.urls.returns }}">سياسة الإرجاع</a></li>
          <li><a href="{{ store.urls.blog }}">المدونة</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-contact footer-col">
        <h4>تواصل معنا</h4>
        {% if store.address %}<p><span>📍</span>{{ store.address }}</p>{% endif %}
        {% if store.phone %}<p><span>📞</span>{{ store.phone }}</p>{% endif %}
        {% if store.email %}<p><span>✉️</span>{{ store.email }}</p>{% endif %}
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {{ "now"|date("Y") }} {{ store.name }}. جميع الحقوق محفوظة.</p>
      <div class="footer-badges">
        <span class="f-badge">SSL Secured</span>
        <span class="f-badge">KSA 🇸🇦</span>
      </div>
    </div>
  </div>
</footer>

<button class="scroll-top" id="scrollTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>
