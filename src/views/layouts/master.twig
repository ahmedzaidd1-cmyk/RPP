{# ############## Shared Variables in all views ################
| Variable                                           | Type     | Description                                                                                              |
|----------------------------------------------------|----------|----------------------------------------------------------------------------------------------------------|
| store                                              | Store    |                                                                                                          |
| store.id                                           | int      |                                                                                                          |
| store.name                                         | string   |                                                                                                          |
| store.username                                     | string   |                                                                                                          |
| store.description                                  | string   |                                                                                                          |
| store.slogan                                       | ?string  | * if feature in twilight.json                                                                            |
| store.logo                                         | string   |                                                                                                          |
| store.url                                          | string   |                                                                                                          |
| store.api                                          | string   | the api url for current store                                                                            |
| store.icon                                         | string   | *fav icon url                                                                                            |
| store.contacts                                     | object   | [mobile, phone, email, whatsapp, telegram], ex. store.contacts.email                                     |
| store.social                                       | object   | [instagram, snapchat, twitter, youtube, facebook, pinterest, maroof, whatsapp], ex. store.social.twitter |
| store.settings                                     | object   |                                                                                                          |
| store.settings.auth.email_allowed                  | bool     |                                                                                                          |
| store.settings.auth.mobile_allowed                 | bool     |                                                                                                          |
| store.settings.auth.is_email_required              | bool     |                                                                                                          |
| store.settings.cart.apply_coupon_enabled           | bool     | Does visitor allowed to applay coupon in cart page                                                       |
| store.settings.product.total_sold_enabled          | bool     |                                                                                                          |
| store.settings.product.fit_type                    | ?string  | null when equal product card size is off, or ['cover', 'contain']                                        |
| store.settings.category.testimonial_enabled        | bool     | Show random testimonials in category page                                                                |
| store.settings.tax.number                          | ?string  |                                                                                                          |
| store.settings.tax.certificate                     | ?string  | certificate image url                                                                                    |
| store.settings.tax.taxable_prices_enabled          | bool     | Does tax included in the prices ex product_price 100 & tax is 15, price will be 115                      |
| store.settings.rating_enabled                      | bool     | Is one of: store_enabled or shipping_enabled or products_enabled                                         |
| store.settings.arabic_numbers_enabled              | bool     | Does the merchant wants the numbers to be shown as Arabic format                                         |
| store.settings.is_multilingual                     | bool     |                                                                                                          |
| store.settings.currencies_enabled                  | bool     |     
| theme                                              | Theme    |                                                                                                          |
| theme.id                                           | int      |                                                                                                          |
| theme.name                                         | string   |                                                                                                          |
| theme.mode                                         | string   | `live`, `preview`                                                                                        |
| theme.is_rtl                                       | bool     |                                                                                                          |
| theme.translations_hash                            | int      | to be used in case merchant updated frontend store translations                                          |
| theme.color                                        | object   |                                                                                                          |
| theme.color.primary                                | string   |                                                                                                          |
| theme.color.text                                   | string   | suitable text color comparing to `theme.primary.color`, #000000, #FFFFFF                                 |
| theme.color.reverse_primary                        | string   |                                                                                                          |
| theme.color.reverse_text                           | string   | if `theme.text_color=#000000` means that `theme.reverse_text_color=#FFFFFF`                              |
| theme.color.is_dark                                | bool     | Does main store color `theme.primary.color` considered as dim color?                                     |
| theme.color.darker(float alpha, ?string hexColor)  | string   | get darker color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0             |
| theme.color.lighter(float alpha, ?string hexColor) | string   | get lighter color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0            |
| theme.font                                         | ?object  | Salla predefined font, null when the theme doesn't have `fonts` feature                                  |
| theme.font.name                                    | string   | DINNextLTArabic-Regular, Amazon-Ember, Apple, Dubai, Estedad                                             |
| theme.font.url                                     | string   | css full url ex: 'https://my_store.test/dist/fonts/default.css'                                          |
| theme.settings                                     | object   | dynamic object with values of the `settings` in twilight.json ex. `theme.settings.topnav_is_dark`        |
| theme.settings.set(settingName, value)             | string   | set global var, then get it {{theme.settings.get('my_var','fallback') }}                                 |
| theme.settings.get(settingName, default=null)      | mixed    | get theme setting ex `theme.settings.get('my_var', 'fallback')`                                          |
#}
<!DOCTYPE html>
<html lang="{{ user.language.code }}" dir="{{ user.language.dir }}">
<!-- بسم الله الرحمن الرحيم -->
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ theme.settings.set('placeholder', 'images/placeholder.png') }}

    <script defer data-cfasync="false" crossorigin="anonymous" src="{{ 'product-card.js'|asset }}"></script>
    <script defer src="{{ 'main-menu.js'|asset }}"></script>
    {% if theme.settings.get('enable_add_product_toast', true) %}
        <script defer src="{{ 'add-product-toast.js'|asset }}"></script>
    {% endif %}

    {% block head_scripts %}{% endblock %}


    <script data-cfasync="false">
        window.header_is_sticky = "{{theme.settings.get('header_is_sticky', 'Default Value')}}"
        window.imageZoom = "{{theme.settings.get('imageZoom')}}"
        window.can_access_wallet = {{ user.can_access_wallet | json_encode }}
        window.enable_more_menu = "{{ theme.settings.get('enable_more_menu', true) }}"
        window.enable_add_product_toast = "{{ theme.settings.get('enable_add_product_toast', true) }}"
    </script>
    
    {% hook 'head:start' %}
    {% hook head %}
    {% block styles %}{% endblock %}
    <link rel="stylesheet" href="{{ 'app.css' | asset }}">
    <link rel="stylesheet" href="{{ theme.font.path|cdn }}"/>
    <link rel="stylesheet" href="{{ 'fonts/sallaicons.css'|cdn }}"/>
    
    <style>
        :root {
            --font-main: '{{theme.font.name}}';
            --color-primary: {{ theme.color.primary }};
            --color-primary-dark: {{ theme.color.darker(0.15) }};
            --color-primary-light: {{ theme.color.lighter(0.15) }};
            --color-primary-reverse: {{ theme.color.reverse_text }};
        }
    </style>
    {# tracking services, custom css feature. #}
    {% hook 'head:end' %}
    <style>
        /* ════ RPP CUSTOM THEME ════ */
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@300;400;500;600;700;900&family=Bebas+Neue&display=swap');
        :root{--rpp-primary:#1A1A2E;--rpp-primary-mid:#16213E;--rpp-accent:#E63946;--rpp-accent-dark:#B5282E;--rpp-accent-light:#FF4D5A;--rpp-gold:#F4A261;--rpp-off-white:#F8F8FB;--rpp-light-grey:#EEF0F5;--rpp-grey:#A8B4C8;--rpp-grey-dark:#5A6A82;--rpp-text:#1A1A2E;--rpp-text-muted:#6B7A96;--rpp-border:#E2E6EE;--rpp-shadow-sm:0 2px 12px rgba(26,26,46,.07);--rpp-shadow-md:0 8px 32px rgba(26,26,46,.12);--rpp-shadow-lg:0 20px 60px rgba(26,26,46,.18);--rpp-radius:8px;--rpp-radius-lg:16px;--rpp-transition:all .3s ease}
        body{font-family:'Tajawal',sans-serif!important}

        /* TOP BAR */
        .top-bar{background:var(--rpp-primary);padding:9px 0;border-bottom:1px solid rgba(255,255,255,.06)}
        .top-bar-inner{display:flex;align-items:center;justify-content:space-between;gap:16px}
        .top-bar-left{display:flex;align-items:center;gap:24px}
        .top-bar-item{display:flex;align-items:center;gap:7px;color:rgba(255,255,255,.55);font-size:0.78rem;font-weight:500}
        .top-bar-right{display:flex;align-items:center;gap:14px}
        .lang-pill{display:flex;align-items:center;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:3px;gap:2px}
        .lang-btn{padding:4px 13px;border-radius:16px;font-size:0.72rem;font-weight:700;color:rgba(255,255,255,.45);transition:var(--rpp-transition)}
        .lang-btn.active{background:var(--rpp-accent);color:white}
        .social-bar{display:flex;gap:6px}
        .soc{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.45);font-size:0.72rem;transition:var(--rpp-transition)}
        .soc:hover{background:var(--rpp-accent);border-color:var(--rpp-accent);color:white}

        /* HEADER */
        .rpp-header{background:white;border-bottom:1px solid var(--rpp-border);position:sticky;top:0;z-index:200;box-shadow:var(--rpp-shadow-sm)}
        .nav-inner{display:flex;align-items:center;justify-content:space-between;height:72px;gap:20px}
        .nav-logo{display:flex;align-items:center;gap:12px;flex-shrink:0}
        .logo-mark{width:42px;height:42px;background:var(--rpp-accent);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue';font-size:1.1rem;color:white;flex-shrink:0}
        .logo-name{font-family:'Cairo',sans-serif;font-size:1.3rem;font-weight:900;color:var(--rpp-text);display:block}
        .logo-tagline{font-size:0.62rem;font-weight:600;color:var(--rpp-grey);letter-spacing:.5px;display:block;text-transform:uppercase}
        .nav-search{flex:1;max-width:480px;position:relative}
        .nav-search input{width:100%;height:44px;border:2px solid var(--rpp-border);border-radius:var(--rpp-radius);padding:0 20px 0 50px;font-size:0.9rem;font-family:inherit;color:var(--rpp-text);background:var(--rpp-off-white);outline:none;transition:var(--rpp-transition)}
        .nav-search input:focus{border-color:var(--rpp-accent);background:white;box-shadow:0 0 0 3px rgba(230,57,70,.08)}
        .nav-actions{display:flex;align-items:center;gap:6px}
        .nav-action{display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 10px;border-radius:var(--rpp-radius);color:var(--rpp-grey-dark);font-size:0.68rem;font-weight:600;transition:var(--rpp-transition);position:relative;cursor:pointer;text-decoration:none}
        .nav-action:hover{color:var(--rpp-accent);background:rgba(230,57,70,.05)}
        .cart-badge{position:absolute;top:2px;right:6px;width:18px;height:18px;background:var(--rpp-accent);color:white;border-radius:50%;font-size:0.6rem;font-weight:700;display:flex;align-items:center;justify-content:center}
        .nav-main{border-top:1px solid var(--rpp-border);background:white}
        .nav-main-inner{display:flex;align-items:center;gap:2px;height:48px;overflow-x:auto}
        .nav-link{display:flex;align-items:center;gap:5px;padding:6px 14px;color:var(--rpp-grey-dark);font-size:0.88rem;font-weight:600;border-radius:4px;transition:var(--rpp-transition);white-space:nowrap;text-decoration:none}
        .nav-link:hover,.nav-link.active{color:var(--rpp-accent);background:rgba(230,57,70,.05)}
        .nav-link-badge{background:var(--rpp-accent);color:white;font-size:0.58rem;font-weight:700;padding:2px 6px;border-radius:10px;margin-right:4px}

        /* HERO */
        .rpp-hero{position:relative;overflow:hidden;background:var(--rpp-primary)}
        .hero-slides{position:relative;height:620px}
        .hero-slide{position:absolute;inset:0;opacity:0;transition:opacity .9s ease,transform 1.2s ease;transform:scale(1.03);z-index:1}
        .hero-slide.active{opacity:1;transform:scale(1);z-index:2}
        .hero-slide-bg{position:absolute;inset:0;background-size:cover;background-position:center}
        .hero-slide-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(100deg,rgba(26,26,46,.92) 35%,rgba(26,26,46,.4) 70%,transparent 100%)}
        .hero-slide-content{position:absolute;inset:0;z-index:3;display:flex;align-items:center}
        .hero-content-inner{max-width:580px;padding:0 60px}
        .slide-label{display:inline-flex;align-items:center;gap:8px;background:rgba(230,57,70,.15);border:1px solid rgba(230,57,70,.3);color:#FF8A93;padding:6px 16px;border-radius:2px;font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:22px}
        .slide-pulse{width:6px;height:6px;background:var(--rpp-accent-light);border-radius:50%;animation:pulse-dot 1.5s infinite;display:inline-block}
        @keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.7)}}
        .hero-title{font-family:'Cairo',sans-serif;font-size:clamp(2.4rem,4.5vw,4.2rem);font-weight:900;color:white;line-height:1.1;margin-bottom:18px}
        .hero-title .accent{color:var(--rpp-accent-light)}
        .hero-title .outline{-webkit-text-stroke:2px rgba(255,255,255,.3);color:transparent;display:block}
        .hero-sub{color:rgba(255,255,255,.65);font-size:1rem;line-height:1.9;margin-bottom:36px;max-width:420px}
        .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
        .hero-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:50px;height:50px;background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.2);backdrop-filter:blur(8px);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:1.2rem;transition:var(--rpp-transition);cursor:pointer}
        .hero-arrow:hover{background:var(--rpp-accent);border-color:var(--rpp-accent)}
        .hero-prev{right:24px}
        .hero-next{left:24px}
        .hero-dots{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:10}
        .hero-dot{width:8px;height:8px;border-radius:4px;background:rgba(255,255,255,.35);border:none;cursor:pointer;transition:all .3s}
        .hero-dot.active{background:var(--rpp-accent);width:24px}
        .hero-progress{position:absolute;bottom:0;left:0;right:0;height:3px;background:rgba(255,255,255,.1);z-index:10}
        .hero-progress-bar{height:100%;background:var(--rpp-accent);transition:width .12s linear}
        .slide-counter{position:absolute;bottom:28px;right:60px;z-index:10;display:flex;align-items:center;gap:6px;color:rgba(255,255,255,.5);font-size:0.8rem;font-weight:700}
        .slide-current{font-family:'Bebas Neue';font-size:2rem;color:white;line-height:1}

        /* BUTTONS */
        .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:13px 32px;border-radius:var(--rpp-radius);font-size:0.95rem;font-weight:700;transition:var(--rpp-transition);border:2px solid transparent;text-decoration:none;cursor:pointer;font-family:'Tajawal',sans-serif}
        .btn-primary{background:var(--rpp-accent);color:white;border-color:var(--rpp-accent)}
        .btn-primary:hover{background:var(--rpp-accent-light);border-color:var(--rpp-accent-light);box-shadow:0 8px 24px rgba(230,57,70,.35);transform:translateY(-2px)}
        .btn-outline{background:transparent;color:var(--rpp-text);border-color:var(--rpp-border)}
        .btn-outline:hover{border-color:var(--rpp-primary);background:var(--rpp-primary);color:white;transform:translateY(-2px)}
        .btn-white-outline{background:transparent;color:white;border-color:rgba(255,255,255,.4)}
        .btn-white-outline:hover{background:rgba(255,255,255,.1);border-color:white}
        .btn-sm{padding:9px 20px;font-size:0.85rem}

        /* FEATURES BAR */
        .rpp-features-bar{background:white;border-bottom:1px solid var(--rpp-border);padding:22px 0;box-shadow:var(--rpp-shadow-sm)}
        .features-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
        .feat-item{display:flex;align-items:center;gap:14px;padding:0 20px}
        .feat-item+.feat-item{border-right:1px solid var(--rpp-border)}
        .feat-icon{width:44px;height:44px;background:rgba(230,57,70,.08);border-radius:var(--rpp-radius);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.2rem}
        .feat-text strong{display:block;font-size:0.88rem;font-weight:700;color:var(--rpp-text);margin-bottom:2px}
        .feat-text span{font-size:0.78rem;color:var(--rpp-text-muted)}

        /* OFFER BAR */
        .rpp-offer-bar{background:var(--rpp-accent);padding:13px 0;overflow:hidden}
        .offer-track{display:flex;width:max-content;gap:60px;animation:marquee-rtl 30s linear infinite}
        @keyframes marquee-rtl{from{transform:translateX(0)}to{transform:translateX(50%)}}
        .offer-item{display:flex;align-items:center;gap:10px;font-size:0.82rem;font-weight:700;color:white;white-space:nowrap}
        .offer-dot{width:4px;height:4px;background:rgba(255,255,255,.5);border-radius:50%;display:inline-block}

        /* SECTION UTILS */
        .badge{display:inline-flex;align-items:center;gap:8px;font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--rpp-accent);margin-bottom:12px}
        .badge::before{content:'';width:24px;height:2px;background:var(--rpp-accent)}
        .section-heading{font-family:'Cairo',sans-serif;font-size:clamp(1.8rem,3vw,2.8rem);font-weight:900;color:var(--rpp-text);line-height:1.15;margin-bottom:14px}
        .section-heading .highlight{color:var(--rpp-accent)}
        .reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
        .reveal.visible{opacity:1;transform:none}

        /* BANNERS */
        .rpp-banners{padding:50px 0}
        .banners-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:20px}
        .banner-card{border-radius:var(--rpp-radius-lg);overflow:hidden;position:relative;min-height:280px;cursor:pointer}
        .banner-card:hover .banner-bg{transform:scale(1.04)}
        .banner-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .6s ease}
        .banner-overlay{position:absolute;inset:0}
        .banner-body{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:32px 36px;z-index:2}
        .banner-label{font-size:0.72rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:8px}
        .banner-title{font-family:'Cairo',sans-serif;font-size:1.7rem;font-weight:900;color:white;line-height:1.15;margin-bottom:16px}
        .banner-sm .banner-title{font-size:1.4rem}
        .banner-cta{display:inline-flex;align-items:center;gap:7px;background:var(--rpp-accent);color:white;padding:10px 20px;border-radius:var(--rpp-radius);font-size:0.85rem;font-weight:700;transition:var(--rpp-transition)}
        .banner-cta:hover{background:var(--rpp-accent-light)}

        /* PRODUCTS */
        .prod-card{background:white;border-radius:var(--rpp-radius-lg);overflow:hidden;border:1.5px solid var(--rpp-border);transition:var(--rpp-transition);position:relative}
        .prod-card:hover{box-shadow:var(--rpp-shadow-lg);border-color:transparent;transform:translateY(-5px)}
        .prod-card:hover .prod-img{transform:scale(1.07)}
        .prod-card:hover .quick-add{transform:translateY(0)}
        .prod-img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
        .prod-badges{position:absolute;top:12px;right:12px;display:flex;flex-direction:column;gap:6px;z-index:2}
        .prod-badge{padding:4px 10px;border-radius:4px;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
        .badge-new{background:var(--rpp-primary);color:white}
        .badge-sale{background:var(--rpp-accent);color:white}
        .badge-hot{background:var(--rpp-gold);color:white}
        .quick-add{position:absolute;bottom:0;left:0;right:0;background:var(--rpp-primary);color:white;padding:12px;text-align:center;font-size:0.82rem;font-weight:700;transform:translateY(100%);transition:transform .3s ease;z-index:2}
        .prod-body{padding:16px}
        .prod-brand{font-size:0.72rem;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--rpp-grey);margin-bottom:6px}
        .prod-name{font-size:0.95rem;font-weight:700;color:var(--rpp-text);line-height:1.4;margin-bottom:10px}
        .stars{color:var(--rpp-gold);font-size:0.82rem}
        .price-current{font-family:'Cairo',sans-serif;font-size:1.15rem;font-weight:900;color:var(--rpp-accent)}
        .price-old{font-size:0.82rem;color:var(--rpp-grey);text-decoration:line-through}
        .add-btn{width:38px;height:38px;background:var(--rpp-off-white);border-radius:var(--rpp-radius);display:flex;align-items:center;justify-content:center;color:var(--rpp-grey-dark);transition:var(--rpp-transition);border:1.5px solid var(--rpp-border)}
        .add-btn:hover{background:var(--rpp-accent);border-color:var(--rpp-accent);color:white}

        /* TESTIMONIALS */
        .rpp-testimonials{background:var(--rpp-primary);padding:90px 0;position:relative;overflow:hidden}
        .rpp-testimonials::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(230,57,70,.08),transparent 60%)}
        .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
        .testi-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:var(--rpp-radius-lg);padding:32px 28px;transition:var(--rpp-transition);position:relative;overflow:hidden}
        .testi-card:hover{background:rgba(255,255,255,.07);border-color:rgba(230,57,70,.25);transform:translateY(-4px)}
        .testi-card::before{content:'"';position:absolute;top:-8px;right:20px;font-size:6rem;color:rgba(230,57,70,.15);line-height:1}
        .testi-stars{color:var(--rpp-gold);font-size:0.9rem;margin-bottom:14px}
        .testi-text{color:rgba(255,255,255,.7);font-size:0.9rem;line-height:1.9;margin-bottom:20px}
        .testi-author{display:flex;align-items:center;gap:12px}
        .testi-avatar{width:44px;height:44px;border-radius:50%;background:var(--rpp-accent);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:white;flex-shrink:0;overflow:hidden}
        .testi-avatar img{width:100%;height:100%;object-fit:cover}
        .testi-name{font-weight:700;font-size:0.9rem;color:white;display:block}
        .testi-meta{font-size:0.75rem;color:rgba(255,255,255,.4)}

        /* BRANDS */
        .rpp-brands{padding:60px 0;background:white;border-top:1px solid var(--rpp-border)}
        .brands-track-wrap{overflow:hidden;margin-top:32px}
        .brands-track{display:flex;width:max-content;gap:60px;animation:brands-scroll 25s linear infinite}
        @keyframes brands-scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
        .brand-logo{height:40px;width:120px;background:var(--rpp-light-grey);border-radius:var(--rpp-radius);display:flex;align-items:center;justify-content:center;color:var(--rpp-grey-dark);font-size:0.8rem;font-weight:700;flex-shrink:0;transition:var(--rpp-transition);filter:grayscale(1);opacity:.5}
        .brand-logo:hover{filter:none;opacity:1;background:white;box-shadow:var(--rpp-shadow-sm)}

        /* NEWSLETTER */
        .rpp-newsletter{padding:90px 0;background:var(--rpp-off-white)}
        .newsletter-box{background:var(--rpp-primary);border-radius:var(--rpp-radius-lg);padding:70px;position:relative;overflow:hidden;text-align:center}
        .newsletter-box::before{content:'';position:absolute;top:-60px;left:-60px;width:300px;height:300px;border-radius:50%;background:rgba(230,57,70,.08)}
        .newsletter-box::after{content:'';position:absolute;bottom:-80px;right:-80px;width:400px;height:400px;border-radius:50%;background:rgba(230,57,70,.05)}
        .newsletter-inner{position:relative;z-index:2;max-width:540px;margin:0 auto}
        .newsletter-title{font-family:'Cairo',sans-serif;font-size:clamp(1.8rem,3vw,2.6rem);font-weight:900;color:white;margin-bottom:12px;line-height:1.2}
        .newsletter-sub{color:rgba(255,255,255,.55);margin-bottom:32px;line-height:1.8}
        .newsletter-form{display:flex;gap:10px;max-width:440px;margin:0 auto}
        .newsletter-input{flex:1;height:52px;border:2px solid rgba(255,255,255,.12);border-radius:var(--rpp-radius);background:rgba(255,255,255,.06);color:white;padding:0 20px;font-family:inherit;font-size:0.93rem;outline:none;transition:var(--rpp-transition)}
        .newsletter-input:focus{border-color:var(--rpp-accent)}
        .nl-btn{height:52px;padding:0 28px;background:var(--rpp-accent);color:white;border-radius:var(--rpp-radius);font-size:0.93rem;font-weight:700;transition:var(--rpp-transition);border:none;cursor:pointer;font-family:'Tajawal',sans-serif}
        .nl-btn:hover{background:var(--rpp-accent-light)}

        /* FOOTER */
        .rpp-footer{background:var(--rpp-primary-mid)!important;color:white;padding:70px 0 0}
        .footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1.2fr;gap:50px;margin-bottom:60px}
        .footer-brand p{color:rgba(255,255,255,.4);font-size:0.87rem;line-height:1.9;margin-top:16px;max-width:260px}
        .footer-col h4{font-size:0.82rem;font-weight:700;letter-spacing:.5px;color:rgba(255,255,255,.4);text-transform:uppercase;margin-bottom:20px}
        .footer-col ul{display:flex;flex-direction:column;gap:10px}
        .footer-col a{color:rgba(255,255,255,.6);font-size:0.88rem;transition:var(--rpp-transition);display:inline-flex;align-items:center;gap:6px}
        .footer-col a:hover{color:white}
        .footer-contact p{display:flex;align-items:flex-start;gap:10px;color:rgba(255,255,255,.55);font-size:0.86rem;margin-bottom:12px;line-height:1.6}
        .footer-social{display:flex;gap:8px;margin-top:20px}
        .footer-soc{width:36px;height:36px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--rpp-radius);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);font-size:0.8rem;transition:var(--rpp-transition)}
        .footer-soc:hover{background:var(--rpp-accent);border-color:var(--rpp-accent);color:white}
        .payment-methods{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px}
        .pay-badge{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);padding:6px 12px;border-radius:4px;font-size:0.72rem;font-weight:700;color:rgba(255,255,255,.45);text-transform:uppercase}
        .footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding:22px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
        .footer-copy{color:rgba(255,255,255,.3);font-size:0.8rem}
        .footer-badges{display:flex;gap:8px}
        .f-badge{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);padding:5px 12px;border-radius:3px;font-size:0.68rem;font-weight:700;color:rgba(255,255,255,.4);text-transform:uppercase}

        /* SCROLL TOP */
        .scroll-top{position:fixed;bottom:28px;left:28px;width:44px;height:44px;background:var(--rpp-accent);color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 20px rgba(230,57,70,.4);cursor:pointer;opacity:0;transform:translateY(10px);transition:var(--rpp-transition);z-index:500;font-size:1rem;border:none}
        .scroll-top.visible{opacity:1;transform:none}
        .scroll-top:hover{background:var(--rpp-accent-light)}

        /* RESPONSIVE */
        @media(max-width:900px){
            .features-grid{grid-template-columns:repeat(2,1fr)}
            .banners-grid{grid-template-columns:1fr}
            .testi-grid{grid-template-columns:1fr}
            .footer-grid{grid-template-columns:1fr 1fr;gap:32px}
            .newsletter-box{padding:40px 28px}
        }
        @media(max-width:600px){
            .top-bar{display:none}
            .hero-slides{height:420px}
            .hero-title{font-size:2rem}
            .hero-sub{display:none}
            .footer-grid{grid-template-columns:1fr}
            .newsletter-form{flex-direction:column}
            .testi-grid{grid-template-columns:1fr}
        }
    </style>

</head>
<body id="app" class="theme-raed overflow-x-hidden {% hook 'body:classes' %}
  {{ theme.settings.get('footer_is_dark') ? ' footer-is-dark' : ' footer-is-light' }}
  {{ theme.settings.get('topnav_is_dark') ? ' topnav-is-dark' : '' }}
  {{ theme.settings.get('sticky_add_to_cart') ? ' is-sticky-product-bar' : '' }}
  ">
<noscript>
    To get full functionality of this site you need to enable JavaScript. Here is how
    <a href="https://www.enable-javascript.com/" rel="noreferrer"
       target="_blank">To enable JavaScript on webpage</a>.
</noscript>
<div class="app-inner flex flex-col min-h-full">
    {% hook 'body:start' %}
    {% component 'header.header' %}
    <main id="main-content" role="main">
    {% block content %}{% endblock %}
    </main>
    {% component 'footer.footer' %}
</div>
{% hook 'body:end' %}
{% if theme.settings.get('enable_add_product_toast', true) %}
    <salla-add-product-toast></salla-add-product-toast>
{% endif %}
<script defer crossorigin="anonymous" src="{{ 'app.js' | asset }}"></script>

{# Twilight Components #}
<salla-offer-modal></salla-offer-modal>
<salla-search></salla-search>

{% if user.type=='guest' %}
    <salla-login-modal></salla-login-modal>
{% endif %}
{% if store.scope %}
    <salla-scopes selection="{{ store.scope.display_as == 'popup' ? 'mandatory' : 'optional' }}"></salla-scopes>
{% endif %}
{% block scripts %}{% endblock %}

<script>
/* RPP HERO SLIDER */
document.addEventListener('DOMContentLoaded', function(){
  var slides = document.querySelectorAll('.hero-slide');
  var dots = document.querySelectorAll('.hero-dot');
  var progressBar = document.getElementById('heroProgress');
  var counterEl = document.getElementById('slideCurrentNum');
  if (!slides.length) return;
  var current = 0, timer = null;
  var DURATION = 5000;

  function goTo(i) {
    slides[current].classList.remove('active');
    if(dots[current]) dots[current].classList.remove('active');
    current = (i + slides.length) % slides.length;
    slides[current].classList.add('active');
    if(dots[current]) dots[current].classList.add('active');
    if(counterEl) counterEl.textContent = String(current+1).padStart(2,'0');
    resetProgress();
  }
  function resetProgress() {
    if(!progressBar) return;
    progressBar.style.transition = 'none';
    progressBar.style.width = '0%';
    requestAnimationFrame(function(){ requestAnimationFrame(function(){
      progressBar.style.transition = 'width '+DURATION+'ms linear';
      progressBar.style.width = '100%';
    });});
  }
  function startAuto() {
    clearInterval(timer);
    timer = setInterval(function(){ goTo(current+1); }, DURATION);
    resetProgress();
  }
  var prevBtn = document.getElementById('heroPrev');
  var nextBtn = document.getElementById('heroNext');
  if(prevBtn) prevBtn.onclick = function(){ clearInterval(timer); goTo(current-1); startAuto(); };
  if(nextBtn) nextBtn.onclick = function(){ clearInterval(timer); goTo(current+1); startAuto(); };
  dots.forEach(function(d,i){ d.onclick = function(){ clearInterval(timer); goTo(i); startAuto(); }; });
  startAuto();

  /* SCROLL REVEAL */
  var revObs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting) e.target.classList.add('visible'); });
  }, {threshold:0.08});
  document.querySelectorAll('.reveal').forEach(function(el){ revObs.observe(el); });

  /* SCROLL TO TOP */
  var scrollBtn = document.getElementById('scrollTop');
  if(scrollBtn) {
    window.addEventListener('scroll', function(){
      scrollBtn.classList.toggle('visible', window.scrollY > 400);
    }, {passive:true});
  }
});
</script>

</body>
</html>
